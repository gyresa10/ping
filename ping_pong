            self.rect.y -= 5
        if Keys_pressed[pygame.K_s] and not (self.rect.y == height_ds - self.height):
            self.rect.y += 5

    def update_keyboardws2(self):
        Keys_pressed = pygame.key.get_pressed()
        if Keys_pressed[pygame.K_UP] and not (self.rect.y == 0) :
            self.rect.y -= 5
        if Keys_pressed[pygame.K_DOWN] and not (self.rect.y == height_ds - self.height):
            self.rect.y += 5
    

class Ball(GameSprite):
    def __init__(self, x, y, width, height, speed, color = None):
        super().__init__(x, y, width, height, color = None)
        self.rect = pygame.Rect(x, y, width, height)
        self.color = color
        self.rect.x = x
        self.rect.y = y
        self.height = height
        self.width = width
        self.dx = speed
        self.dy = speed
        self.no_lose = False
    
    def update(self, listt):
        rect1 = listt[0]
        rect2 = listt[1]
        self.rect.x += self.dx
        self.rect.y += self.dy
        if self.colliderect(rect1.rect):
            self.dx *= -1
        if self.colliderect(rect2.rect):
            self.dx *= -1
        #надо сделать так что-бы шар при столкновении с боковой частью игрока менялcя свои вектора (dy *= -1 и dx *= -1)
        if self.rect.y > height_ds or self.rect.y < 0:
            self.dy *= -1
        if self.no_lose == True:
            if self.rect.x > widht_ds or self.rect.x < 0:
                self.dx *= -1
    
    def set_no_lose(self):
        self.no_lose = True

